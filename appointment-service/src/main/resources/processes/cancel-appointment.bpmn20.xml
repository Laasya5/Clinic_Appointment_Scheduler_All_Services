<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="http://www.omg.org/spec/BPMN/20100524/MODEL"
             xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
             xmlns:flowable="http://flowable.org/bpmn"
             xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI"
             xmlns:dc="http://www.omg.org/spec/DD/20100524/DC"
             xmlns:di="http://www.omg.org/spec/DD/20100524/DI"
             targetNamespace="Examples">

    <process id="cancelAppointmentProcess"
             name="Cancel Appointment Process"
             isExecutable="true">

        <startEvent id="startEvent" name="Start"/>

        <sequenceFlow id="flow1"
                      sourceRef="startEvent"
                      targetRef="cancelTask"/>

        <serviceTask id="cancelTask"
                     name="Cancel Appointment"
                     flowable:delegateExpression="${cancelAppointmentDelegate}"/>

        <sequenceFlow id="flow2"
                      sourceRef="cancelTask"
                      targetRef="freeSlotTask"/>

        <serviceTask id="freeSlotTask"
                     name="Free Slot"
                     flowable:delegateExpression="${freeSlotDelegate}"/>

        <sequenceFlow id="flow3"
                      sourceRef="freeSlotTask"
                      targetRef="publishTask"/>

        <serviceTask id="publishTask"
                     name="Publish Kafka"
                     flowable:delegateExpression="${publishCancellationDelegate}"/>

        <sequenceFlow id="flow4"
                      sourceRef="publishTask"
                      targetRef="endEvent"/>

        <endEvent id="endEvent" name="End"/>

    </process>

    <!-- DIAGRAM SECTION -->
    <bpmndi:BPMNDiagram id="BPMNDiagram_1">
        <bpmndi:BPMNPlane id="BPMNPlane_1"
                          bpmnElement="cancelAppointmentProcess">

            <bpmndi:BPMNShape id="StartEvent_di"
                              bpmnElement="startEvent">
                <dc:Bounds x="100" y="150" width="36" height="36"/>
            </bpmndi:BPMNShape>

            <bpmndi:BPMNShape id="CancelTask_di"
                              bpmnElement="cancelTask">
                <dc:Bounds x="200" y="130" width="150" height="80"/>
            </bpmndi:BPMNShape>

            <bpmndi:BPMNShape id="FreeSlot_di"
                              bpmnElement="freeSlotTask">
                <dc:Bounds x="400" y="130" width="150" height="80"/>
            </bpmndi:BPMNShape>

            <bpmndi:BPMNShape id="PublishTask_di"
                              bpmnElement="publishTask">
                <dc:Bounds x="600" y="130" width="150" height="80"/>
            </bpmndi:BPMNShape>

            <bpmndi:BPMNShape id="EndEvent_di"
                              bpmnElement="endEvent">
                <dc:Bounds x="800" y="150" width="36" height="36"/>
            </bpmndi:BPMNShape>

            <bpmndi:BPMNEdge id="Flow1_di" bpmnElement="flow1">
                <di:waypoint x="136" y="168"/>
                <di:waypoint x="200" y="168"/>
            </bpmndi:BPMNEdge>

            <bpmndi:BPMNEdge id="Flow2_di" bpmnElement="flow2">
                <di:waypoint x="350" y="168"/>
                <di:waypoint x="400" y="168"/>
            </bpmndi:BPMNEdge>

            <bpmndi:BPMNEdge id="Flow3_di" bpmnElement="flow3">
                <di:waypoint x="550" y="168"/>
                <di:waypoint x="600" y="168"/>
            </bpmndi:BPMNEdge>

            <bpmndi:BPMNEdge id="Flow4_di" bpmnElement="flow4">
                <di:waypoint x="750" y="168"/>
                <di:waypoint x="800" y="168"/>
            </bpmndi:BPMNEdge>

        </bpmndi:BPMNPlane>
    </bpmndi:BPMNDiagram>

</definitions>